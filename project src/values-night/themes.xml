<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Dark Mode. -->
    <style name="Theme.RRMS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primaryBlue</item>
        <item name="colorPrimaryVariant">@color/primaryDarkBlue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primaryBlue</item>
        <item name="colorSecondaryVariant">@color/primaryDarkBlue</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/darkBackground</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/darkBackground</item>

        <!-- AlertDialog Style -->
        <item name="alertDialogTheme">@style/CustomAlertDialogTheme</item>
    </style>
</resources>
