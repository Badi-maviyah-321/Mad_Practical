<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/cardBackground"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BASIC INFORMATION"
                        android:textColor="@color/textSecondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/etTenantName"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="Full Name"
                        android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_input_dark"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textSecondary"
                        android:layout_marginBottom="16dp"
                        android:inputType="textPersonName"/>

                    <EditText
                        android:id="@+id/etTenantRoom"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="Room Number"
                        android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_input_dark"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textSecondary"
                        android:layout_marginBottom="16dp"
                        android:inputType="text"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/etMonthlyRent"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:hint="Rent (₹)"
                            android:inputType="number"
                            android:paddingHorizontal="16dp"
                            android:background="@drawable/bg_input_dark"
                            android:textColor="@color/white"
                            android:textColorHint="@color/textSecondary"
                            android:layout_marginEnd="8dp"/>

                        <EditText
                            android:id="@+id/etSecurityDeposit"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:hint="Deposit (₹)"
                            android:inputType="number"
                            android:paddingHorizontal="16dp"
                            android:background="@drawable/bg_input_dark"
                            android:textColor="@color/white"
                            android:textColorHint="@color/textSecondary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTACT DETAILS"
                        android:textColor="@color/textSecondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_dark"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <com.hbb20.CountryCodePicker
                            android:id="@+id/ccp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:ccp_defaultNameCode="IN"
                            app:ccp_contentColor="@color/white"
                            app:ccp_showNameCode="false"
                            app:ccp_padding="0dp"/>

                        <EditText
                            android:id="@+id/etTenantPhone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Phone Number"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:background="@android:color/transparent"
                            android:textColor="@color/white"
                            android:textColorHint="@color/textSecondary"
                            android:paddingStart="8dp"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etTenantEmail"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="Email Address"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_input_dark"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textSecondary"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/etTenantPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="Access Password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_input_dark"
                        android:textColor="@color/white"
                        android:textColorHint="@color/textSecondary"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOCUMENTS"
                        android:textColor="@color/textSecondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="32dp">

                        <Button
                            android:id="@+id/btnSelectDocs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/primaryBlue"
                            android:textColor="@color/white"
                            app:cornerRadius="12dp"/>

                        <TextView
                            android:id="@+id/tvSelectedDocs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No document selected"
                            android:textColor="@color/textSecondary"
                            android:paddingStart="16dp"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnSaveTenant"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Confirm Registration"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primaryBlue"
                        app:cornerRadius="16dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>